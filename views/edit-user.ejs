<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/edit.css">
</head>
<body>
    <div class="edit">
        <h1>Profile Information</h1>
        <form action="/edit-user" method="post">
           <label>
               <p>Email: </p><input type="text" name="email" value="<%=user?.email %>">
           </label>
            
           <label>
               <p>Name: </p><input type="text" name="name" value="<%=user.name %>">
           </label>

           <label>
               <p>City: </p><input type="text" name="city" value="<%=user.city %>">
           </label>
    
           <label>
               <p>District: </p><input type="text" name="district" value="<%=user.district %>">   
           </label>
           <%if(success!=null){%>
                <p><%=success%></p>
            <%}%>
            <button type="submit">Edit</button>
        </form>
        </div>

    <a style=" display: block;margin: 0px auto; width: fit-content;" href="/userpage">Back to Consumer Page</a>


</body>
</html>