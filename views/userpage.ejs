<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Document</title>
    <link rel="stylesheet" href="/css/userpage.css">
</head>
<body>
    <div class="navbar">
        <a href="/edit-user">
            <img src="/img/profile.png" id="icon">
        </a>

        <form action="/search" method="GET" class="search-box">
            <input type="text" name="q" placeholder="Search products...">
            <button type="submit">Search</button>
        </form>
        
        <a href="/cart" class="btn">Cart 🛒</a>
    </div>

    <h2>Products</h2>
    <% if (success) { %>
        <p class="success-message"><%= success%></p>
    <% } %>
    <div class="products">
    <% if (products && products.length) { %>
        <% products.forEach(product => { %>
            <div class="product-card">

                <img src="/products/<%= product.img %>" class="product-image">

                <h3><%= product.title %></h3>
                <p id="discount">Price: <span>$<%= product.normal_price %></span> $<%= product.discount_price %></p>
                <p>Stock: <%= product.stock %></p>
                <p>Expires: <%= new Date(product.expire_date).toLocaleDateString('en-GB') %></p>

                <form action="/cart/add/<%= product.id%>" method="POST">

                    <button type="submit">
                        Add to Cart
                    </button>
                </form>

            </div>
        <% }) %>
    <% } else { %>
        <p>No products found</p>
    <% } %>
    </div>

</body>
</html>