<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Cart</title>
    <link rel="stylesheet" href="/css/cart.css">
</head>
<body>

    <div class="nav">
        <h2>Your Cart</h2>

        <a href="/consumerpage" class="back">
            ← Back
        </a>
    </div>

    <div id="msg" class="msg" style="display: none;"></div>

    <div class="cart">

        <% if (cart && cart.length) { %>

            <% cart.forEach(item => { %>

                <div class="card" id="item-<%= item.id %>">

                    <img src="/products/<%= item.img %>" class="img">

                    <div class="info">
                        <h3><%= item.title %></h3>

                        <p class="price">
                            <span><%= item.normal_price %></span>
                            <%= item.discount_price %> TL
                        </p>

                        <p>Stock: <%= item.stock %></p>

                        <p>
                            Expires:
                            <%= new Date(item.expire_date).toLocaleDateString('en-GB') %>
                        </p>
                    </div>

                    <div class="qty-box">
                        <button class="qty" onclick="updateQuantity(`<%= item.id %>`, -1)">−</button>
                        <span id="qty-<%= item.id %>"><%= item.quantity %></span>
                        <button class="qty" onclick="updateQuantity(`<%= item.id %>`, 1)">+</button>
                    </div>

                </div>

            <% }) %>

            <div class="footer">
                <h2 class="total">Total: <%= total %> TL</h2>
                <button class="purchase" onclick="processPurchase()">Purchase Now</button>
            </div>

        <% } else { %>

            <p class="empty">Your cart is empty</p>

        <% } %>

    </div>

    <script src="/script/cart.js"></script>
</body>
</html>