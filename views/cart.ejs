<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Cart</title>
    <link rel="stylesheet" href="/css/cart.css">
</head>
<body>

    <div class="nav">
        <h2>Your Cart</h2>
        <a href="/consumerpage" class="back">← Back</a>
    </div>

    <div id="msg" class="msg" style="display: none;"></div>

    <div class="cart">
        <% if (cart && cart.length) { %>
            <% cart.forEach(item => { %>
                <div class="card" id="item<%= item.id %>">
                    <img src="/products/<%= item.img %>" class="img">

                    <div class="info">
                        <h3><%= item.title %></h3>
                        <p class="price">
                            <span><%= item.normal_price %> $</span>
                            <%= item.discount_price %> $
                        </p>
                        <p>Stock: <%= item.stock %></p>
                        <p>Expires: <%= new Date(item.expire_date).toLocaleDateString('tr-TR') %></p>
                    </div>

                    <div class="qty">
                        <button class="qty-btn" onclick="updateQuantity('<%= item.id %>', -1)">-</button>
                        <span id="qty<%= item.id %>"><%= item.quantity %></span>
                        <button class="qty-btn" onclick="updateQuantity('<%= item.id %>', 1)">+</button>
                    </div>

                    <div class="subtotal-box">
                        <p>Subtotal:</p>
                        <span id="subtotal<%= item.id %>" class="subtotal-val">
                            <%= (item.discount_price * item.quantity).toFixed(2) %> $
                        </span>
                    </div>

                    <a href='/cart/delete/<%= item.id %>'>
                        <img class="delete" src="/img/delete.png" alt="Delete">
                    </a>
                </div>
            <% }) %>
            <p id="stock-out"> </p>
            <div class="footer">
                <h3 class="total">Total: <span id="cart-total">$<%= total %></span></h3>
                <button class="purchase" onclick="processPurchase()">Purchase Now</button>
            </div>
            <div id="cart-loading" style="display: none; text-align: center; margin-top: 30px;">
                <img src="/img/loading.gif" alt="Loading..." style="width: 80px;">
            </div>
        <% } else { %>
            <p class="empty">Your cart is empty</p>
        <% } %>
    </div>

    <script src="/script/cart.js"></script>
</body>
</html>